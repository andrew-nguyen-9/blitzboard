# Frontend (public) env. Copy to .env.local (gitignored).
# Anon key only — public reads, enforced by Supabase RLS. NEVER the service role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL used to build OAuth/email redirect targets (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
