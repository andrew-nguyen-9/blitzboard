# Frontend (public) env. Copy to .env.local (gitignored).
# Anon key only — public reads, enforced by Supabase RLS. NEVER the service role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL used to build OAuth/email redirect targets (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Staged placeholders (F2): commented until the owning feature lands. ---
# Frontend-facing keys only here; server/pipeline secrets live in
# .env.local.example (and, at runtime, pipeline/.env). NEVER put a real value in
# a committed *.example file.

# hCaptcha public site key — bot-defense widget on auth forms (frontend-facing).
# NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
