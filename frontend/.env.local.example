# Frontend env. Copy to .env.local (gitignored).
# Anon key only — public reads, enforced by Supabase RLS. NEVER the service role key.
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ESPN live draft-sync (SERVER-ONLY secrets — no NEXT_PUBLIC prefix, never sent to
# the browser; used only by the /api/espn/draft route). Needed for PRIVATE leagues.
ESPN_LEAGUE_ID=
ESPN_SEASON=2025
ESPN_S2=
ESPN_SWID=

# ============================================================================
# Staged secret placeholders (F2). All COMMENTED + empty — uncomment and fill in
# .env.local (frontend) or pipeline/.env (server/pipeline) when the owning feature
# lands. HARD policy: free-tier + user-provisioned keys only; never a paid tier;
# every source degrades with NO key. NEVER commit a real value.
# ============================================================================

# --- Auth: Google OAuth (SERVER-ONLY; set in the Supabase Auth dashboard, staged
#     here for parity). Enables "Sign in with Google". ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# --- Auth: hCaptcha bot-defense. Site key is frontend-facing (also in
#     .env.example); secret verifies tokens server-side. Free tier. ---
# NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
# HCAPTCHA_SECRET=

# --- Supabase service-role key: SERVER/PIPELINE ONLY. Lives in pipeline/.env (or
#     GitHub Actions / Supabase vault), NEVER in the client bundle. Bypasses RLS. ---
# SUPABASE_SERVICE_ROLE_KEY=

# --- Data source: betting odds (SERVER/PIPELINE). the-odds-api free tier
#     (~500 req/mo, user-provisioned). Absent → odds features degrade to empty. ---
# ODDS_API_KEY=

# --- Data source: injuries (SERVER/PIPELINE). OPTIONAL — ESPN/Sleeper injury JSON
#     is keyless; set only if a chosen source requires a key. Absent → keyless path. ---
# INJURY_API_KEY=

# --- Data source: college stats (SERVER/PIPELINE). collegefootballdata.com free
#     tier (free user key, rate-limited). Absent → college-stats source degrades. ---
# CFBD_API_KEY=
