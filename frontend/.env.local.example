# Frontend env. Copy to .env.local (gitignored).
# Anon key only — public reads, enforced by Supabase RLS. NEVER the service role key.
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ESPN live draft-sync (SERVER-ONLY secrets — no NEXT_PUBLIC prefix, never sent to
# the browser; used only by the /api/espn/draft route). Needed for PRIVATE leagues.
ESPN_LEAGUE_ID=
ESPN_SEASON=2025
ESPN_S2=
ESPN_SWID=
